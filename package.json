{
  "name": "@1money/mcp",
  "version": "0.3.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "1money-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "schemas",
    "public",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "pnpm": {
    "overrides": {
      "@hono/node-server": "^1.19.10",
      "ajv": "^8.18.0",
      "hono": "^4.12.7",
      "qs": "^6.14.2"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "generate-schemas": "node scripts/generate-schemas.mjs",
    "openapi:map": "node scripts/build-openapi-tool-map.mjs",
    "openapi:sync": "node scripts/sync-openapi-schemas.mjs",
    "test": "tsx --test tests/*.test.ts",
    "prepack": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/1Money-Co/1money-mcp"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "dotenv": "^17.2.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.19.7",
    "json-schema-to-zod": "^2.7.0",
    "tsx": "^4.7.0",
    "typescript": "^5.5.0"
  }
}
